{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TinyForge",
  "version": "0.1.0",
  "identifier": "com.tiny-forge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tiny Forge v0.1.0",
        "width": 490,
        "height": 540,
        "dragDropEnabled": true,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "decorations": false,
        "devtools": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "*"
        ]
      },
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/compressor"
    ]
  },
  "plugins": {
    "store": null,
    "updater": {
      "active": true,
      "endpoints": [
        "https://breno-777.github.io/tiny-forge/latest.json"
      ],
      "pubkey": "<SET_AT_RUNTIME>"
    }
  }
}